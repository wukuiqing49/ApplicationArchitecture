<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="GradientShapeLabelView">
        <!-- 文字内容 -->
        <attr name="label_text" format="string" />
        <attr name="label_text_color" format="color" />
        <attr name="label_text_size" format="dimension" />
        
        <!-- 图标 -->
        <attr name="label_left_icon" format="reference" />
        <attr name="label_right_icon" format="reference" />
        <attr name="label_icon_padding" format="dimension" />
        <attr name="label_icon_size" format="dimension" />

        <!-- 背景渐变与圆角 -->
        <attr name="label_bg_start_color" format="color" />
        <attr name="label_bg_end_color" format="color" />
        <attr name="label_bg_radius" format="dimension" />
        <!-- 渐变方向: 0: LEFT_RIGHT, 1: TOP_BOTTOM, 2: TL_BR (TopLeft-BottomRight) -->
        <attr name="label_bg_orientation" format="enum">
            <enum name="left_right" value="0" />
            <enum name="top_bottom" value="1" />
            <enum name="tl_br" value="2" />
        </attr>
    </declare-styleable>
</resources>
