<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.ApplicationArchitecture" parent="Theme.Material3.DayNight.NoActionBar">
    </style>

    <style name="Theme.ApplicationArchitecture" parent="Base.Theme.ApplicationArchitecture" />

    <!-- 专门给 SplashActivity 用的首屏防黑屏主题 -->
    <style name="Theme.ApplicationArchitecture.Splash" parent="Theme.ApplicationArchitecture">

        <!-- 适配 Android 12+ 的全新 Splash Screen API -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/splash_bg_color</item>

        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:theme">@android:style/Theme.Light.NoTitleBar.Fullscreen</item>
<!--        <item name="android:windowBackground">@drawable/shape_launcher</item>-->
        <!--不让windowBackground延申到navigation bar区域-->
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
    </style>
</resources>
