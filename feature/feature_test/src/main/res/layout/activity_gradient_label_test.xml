<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="GradientShapeLabelView 测试"
        android:textColor="#333333"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- 1. 基本用法：纯色背景 + 文字 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. 纯色背景 + 文字"
        android:layout_marginTop="16dp"
        android:textSize="12sp" />
        
    <com.wkq.ui.widget.GradientShapeLabelView
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:label_bg_radius="20dp"
        app:label_bg_start_color="#2196F3"
        app:label_text="蓝色纯色标签"
        app:label_text_color="#FFFFFF"
        app:label_text_size="14sp" />

    <!-- 2. 左右图标 + 渐变背景 (左右) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. 左右图标 + 渐变背景 (左右)"
        android:layout_marginTop="24dp"
        android:textSize="12sp" />

    <com.wkq.ui.widget.GradientShapeLabelView
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:label_bg_end_color="#FF80AB"
        app:label_bg_orientation="left_right"
        app:label_bg_radius="22dp"
        app:label_bg_start_color="#FF4081"
        app:label_left_icon="@android:drawable/ic_menu_add"
        app:label_right_icon="@android:drawable/ic_menu_send"
        app:label_text="图文渐变标签"
        app:label_text_color="#FFFFFF"
        app:label_text_size="14sp"
        app:label_icon_padding="6dp"
        app:label_icon_size="18dp" />

    <!-- 3. 垂直渐变 + 圆角样式 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3. 垂直渐变 + 矩形圆角"
        android:layout_marginTop="24dp"
        android:textSize="12sp" />

    <com.wkq.ui.widget.GradientShapeLabelView
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:layout_marginTop="8dp"
        app:label_bg_end_color="#4CAF50"
        app:label_bg_orientation="top_bottom"
        app:label_bg_radius="8dp"
        app:label_bg_start_color="#8BC34A"
        app:label_text="大尺寸垂直渐变"
        app:label_text_color="#FFFFFF"
        app:label_text_size="16sp" />

    <!-- 4. 斜向渐变 + 仅文字 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4. 斜向渐变 (TL_BR)"
        android:layout_marginTop="24dp"
        android:textSize="12sp" />

    <com.wkq.ui.widget.GradientShapeLabelView
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:label_bg_end_color="#9C27B0"
        app:label_bg_orientation="tl_br"
        app:label_bg_radius="4dp"
        app:label_bg_start_color="#E91E63"
        app:label_text="斜向渐变标签"
        app:label_text_color="#FFFFFF"
        app:label_text_size="13sp" />

</LinearLayout>
